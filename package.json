{
  "name": "kako",
  "version": "0.0.0",
  "private": true,
  "description": "Kako — Agent Harness personal assistant",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:server": "pnpm --filter @kako/shared build && pnpm --filter @kako/core build && pnpm --filter @kako/server dev",
    "dev:web": "concurrently -k -n api,web -c blue,green \"pnpm dev:server\" \"pnpm --filter @kako/web dev:ui\"",
    "dev:settings": "pnpm dev:web",
    "kako": "kako",
    "link:global": "pnpm --filter @kako/cli link --global",
    "link:dev": "bash scripts/link-dev.sh",
    "rebuild:cli": "pnpm --filter @kako/shared build && pnpm --filter @kako/core build && pnpm --filter @kako/cli build",
    "services": "bash scripts/dev-services.sh",
    "services:start": "bash scripts/dev-services.sh start",
    "services:restart": "bash scripts/dev-services.sh restart",
    "services:stop": "bash scripts/dev-services.sh stop",
    "services:status": "bash scripts/dev-services.sh status",
    "pack": "bash scripts/build-macos-pkg.sh",
    "pack:macos": "bash scripts/build-macos-pkg.sh",
    "test": "turbo run test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "turbo run typecheck",
    "ci": "pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@kako/cli": "workspace:*",
    "@types/node": "^22.15.0",
    "concurrently": "^9.2.0",
    "oxlint": "1.59.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
